    {
        "id": "func-motion",
        "type": "function",
        "z": "4f51d4753e2d1e6f",
        "name": "Motion Publisher",
        "func": "var states = [\"detected\", \"clear\", \"clear\", \"detected\", \"clear\"];\nvar state = states[Math.floor(Math.random() * states.length)];\nmsg.payload = JSON.stringify({\n    sensor: \"motion_01\",\n    status: state,\n    room: \"hallway\",\n    timestamp: new Date().toISOString()\n});\nmsg.topic = \"home_Suriya/hallway/motion\";\nmsg.qos = 2;\nmsg.retain = false;\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 390,
