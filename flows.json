    {
        "id": "func-parse",
        "type": "function",
        "z": "4f51d4753e2d1e6f",
        "name": "Parse & Route",
        "func": "var data;\ntry { data = JSON.parse(msg.payload); } catch (e) { data = msg.payload; }\n\nnode.warn(\"TOPIC: \" + msg.topic + \" | DATA: \" + JSON.stringify(data));\n\nvar out1 = null, out2 = null, out3 = null;\n\nif (msg.topic.includes(\"temperature\")) {\n    out1 = { payload: data.temperature || 0, topic: msg.topic };\n} else if (msg.topic.includes(\"motion\")) {\n    out2 = { payload: data.status === \"detected\" ? 1 : 0, topic: msg.topic };\n}\n\nif (msg.topic.startsWith(\"home_Suriya/\")) {\n    out3 = {\n        payload: \"[\" + msg.topic + \"] \" + JSON.stringify(data),\n        topic: \"home_Suriya/status\"\n    };\n}\n\nreturn [out1, out2, out3];",
        "outputs": 3,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 450,
        "y": 530,
        "wires": [
            [
                "ui-gauge-temp",
                "ui-chart-temp"
            ],
            [
                "func-motion-text"
            ],
            [
                "ui-log",
                "debug-all"
            ]
        ]
    },
    {
